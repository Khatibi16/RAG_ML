    "        m = result[\"metrics\"]\n",
    "        summary[tmpl] = {\"em\": m[\"em\"], \"f1\": m[\"f1\"]}\n",
    "    save_results(\"exp4_summary\", {\"results\": summary})\n",
    "    return exp4_results\n",
    "\n",
